// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum card_category {
  MOB
  EQUIPMENT
  ARTIFACT
}

model actions {
  id            Int      @id @default(autoincrement())
  name          String
  description   String?
  damage        Int?
  cost          Int      @default(0)
  multiTarget   Boolean  @default(false)
  autoActivate  Boolean  @default(false)
  function      Int

  // Relations avec cards
  cards_talent  cards[]  @relation("cards_talent")
  cards_attack1 cards[]  @relation("cards_attack1")
  cards_attack2 cards[]  @relation("cards_attack2")
}

model cards {
  id             Int              @id @default(autoincrement())
  name           String
  description    String
  category       card_category    @default(MOB)
  rarity         Int              @default(1)
  pv_durability  Int
  cost           Int              @default(0)
  talent         Int?
  attack1        Int
  attack2        Int?
  main_img       String
  background_img String
  third_img      String?

  // Relations
  talent_action  actions? @relation("cards_talent", fields: [talent], references: [id])
  attack1_action actions  @relation("cards_attack1", fields: [attack1], references: [id])
  attack2_action actions? @relation("cards_attack2", fields: [attack2], references: [id])

  collections    collection[]
}

model collection {
  id        Int   @id @default(autoincrement())
  user_id   Int
  card_id   Int
  favorite  Boolean @default(false)

  // Relations
  user user @relation(fields: [user_id], references: [id], onDelete: Cascade)
  card cards @relation(fields: [card_id], references: [id])

  deck_cards deck_cards[]
}

model decks {
  id        Int    @id @default(autoincrement())
  user_id   Int
  name      String?
  is_active Boolean?

  // Relations
  user      user         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  deckCards deck_cards[]
}

model deck_cards {
  id            Int   @id @default(autoincrement())
  deck_id       Int
  collection_id Int

  deck       decks      @relation(fields: [deck_id], references: [id], onDelete: Cascade)
  collection collection @relation(fields: [collection_id], references: [id])
}

model inventory {
  id      Int @id @default(autoincrement())
  user_id Int @unique
  keys    Int

  user user @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model point {
  id      Int @id @default(autoincrement())
  user_id Int @unique
  oneVone Int
  iaVone  Int

  user user @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("point")
}

model stat {
  id      Int     @id @default(autoincrement())
  user_id Int @unique
  winRate Decimal @db.Decimal(5, 2)
  nbParty Int

  user user @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model user {
  id            Int       @id @default(autoincrement())
  pseudo        String
  email         String
  password      String
  timeNextChest DateTime

  // Relations
  collections collection[]
  decks       decks[]
  inventory   inventory?
  points      point?
  stats       stat?
}