// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum card_category {
  MOB
  EQUIPMENT
  ARTIFACT
  FORTEMPLATE
}

enum GameMode {
  ONE_V_ONE
  IA_V_ONE
  DONJON
  VAGUES
}

model actions {
  id            Int      @id @default(autoincrement())
  name          String
  description   String?
  damage        Int?
  cost          Int      @default(0)
  multiTarget   Boolean  @default(false)
  autoActivate  Boolean  @default(false)
  function      Int

  // Relations avec cards
  cards_talent  cards[]  @relation("cards_talent")
  cards_attack1 cards[]  @relation("cards_attack1")
  cards_attack2 cards[]  @relation("cards_attack2")
}

model cards {
  id             Int              @id @default(autoincrement())
  name           String           @unique
  description    String
  category       card_category    @default(MOB)
  rarity         Int              @default(1)
  pv_durability  Int
  cost           Int              @default(0)
  talent         Int?
  attack1        Int
  attack2        Int?
  main_img       String
  background_img String
  third_img      String?

  // Relations
  talent_action  actions? @relation("cards_talent", fields: [talent], references: [id])
  attack1_action actions  @relation("cards_attack1", fields: [attack1], references: [id])
  attack2_action actions? @relation("cards_attack2", fields: [attack2], references: [id])

  collections    collection[]
  deck_cards     deck_cards[]  // Relation many-to-many via table de liaison
}

model collection {
  id        Int     @id @default(autoincrement())
  user_id   Int
  card_id   Int?
  quantity  Int     @default(1)
  favorite  Boolean @default(false)

  // Relations
  user user   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  card cards? @relation(fields: [card_id], references: [id])
}

model decks {
  id        Int         @id @default(autoincrement())
  user_id   Int
  name      String?
  is_active Boolean     @default(false)

  // Relations
  user       user         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  deck_cards deck_cards[] // Les cartes de ce deck
}

// Table de liaison pour la relation many-to-many entre decks et cards
model deck_cards {
  id       Int @id @default(autoincrement())
  deck_id  Int
  card_id  Int
  quantity Int @default(1) // Nombre d'exemplaires de cette carte

  // Relations
  deck decks @relation(fields: [deck_id], references: [id], onDelete: Cascade)
  card cards @relation(fields: [card_id], references: [id], onDelete: Cascade)

  @@unique([deck_id, card_id]) // Garde l'unique mais utilise quantity pour compter
}

model inventory {
  id      Int @id @default(autoincrement())
  user_id Int @unique
  keys    Int

  user user @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model game_stats {
  id        Int      @id @default(autoincrement())
  user_id   Int
  game_mode GameMode
  
  // Statistiques de jeu
  nb_party  Int      @default(0)
  victories Int      @default(0)
  defeats   Int      @default(0)
  
  // Points gagnés dans ce mode
  points    Int      @default(0)
  
  // Relations
  user      user     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  
  // Un utilisateur ne peut avoir qu'une seule entrée par mode de jeu
  @@unique([user_id, game_mode])
}

model user {
  id            Int       @id @default(autoincrement())
  pseudo        String
  email         String
  password      String
  timeNextChest DateTime

  // Relations
  collections collection[]
  decks       decks[]
  inventory   inventory?
  game_stats       game_stats[]
}